Q;EACI,kBAAA;AApCZ;AAYA;EA4BY,wBAAA;AArCZ;AASA;EA+BgB,wBAAA;AArChB;AA2CA;EAnCI,aAAA;EACA,cAAA;EACA,kBAAA;EACA,sFAAA;EAkCA,mBAAA;AAtCJ;AAoCA;EA7BQ,wBAAA;AAJR;AAiCA;EA1BY,cAAA;EACA,WAAA;EACA,YAAA;AAJZ;AAUQ;EACI,mBAAA;AARZ;AAWQ;EACI,kBAAA;AATZ;AAsBA;EATY,wBAAA;AAVZ;AAmBA;EANgB,wBAAA;AAVhB;AAqBA;EACI,eAAA;EAGA,gCAAA;AArBJ;AAuBI;EACI,uFAAA;AArBR;AAyBA;EACI,YAAA;EACA,cAAA;AAvBJ;AA0BA;EACI,aAAA;EACA,uBAAA;AAxBJ;AA2BA;EACI,WAAA;EACA,qBAAA;EACA,YAAA;EACA,eAAA;EACA,+BAAA;AAzBJ;AA4BA;EACI,cAAA;AA1BJ;AA4BI;EACI,iBAAA;AA1BR;AA6BI;EACI,gBAAA;AA3BR;AA+BA;EACI,+BAAA;EACA,eAAA;EACA,iBAAA;EACA,kBAAA;EACA,SAAA;EACA,YAAA;EACA,eAAA;EACA,cAAA;EACA,kBAAA;EACA,yBAAA;EACA,cAAA;EACA,kBAAA;EACA,uBAAA;AA7BJ;AA+BI;EACI,SAAA;AA7BR;AAgCI;EACI,UAAA;AA9BR;AAkCA;EACI,eAAA;AAhCJ;AAmCA;EACI,kBAAA;EACA,gBAAA;AAjCJ;AAoCA;EACI,aAAA;EACA,mBAAA;EACA,WAAA;AAlCJ;AAqCA;EACI,mBAAA;AAnCJ;AAsCA;EACI,aAAA;EACA,sBAAA;EACA,WAAA;AApCJ;AAuCA;EACI,mBAAA;EACA,kBAAA;AArCJ;AAwCA;EACI,WAAA;AAtCJ;AAyCA;EACI,sBAAA;AAvCJ;AA0CA;EACI,kBAAA;AAxCJ;AA2CA;EACI,cAAA;AAzCJ;AA4CA;EACI,gBAAA;EACA,uBAAA;EACA,mBAAA;AA1CJ;AA6CA;EACI,WAAA;EACA,cAAA;EACA,gCAAA;EACA,qBAAA;AA3CJ;AA6CI;;EAEI,cAAA;EACA,0BAAA;AA3CR;AA8CI;EACI,cAAA;AA5CR;AAgDA;EAtBI,gBAAA;EACA,uBAAA;EACA,mBAAA;EAIA,WAAA;EACA,cAAA;EACA,gCAAA;EACA,qBAAA;AA1BJ;AA4BI;;EAEI,cAAA;EACA,0BAAA;AA1BR;AA6BI;EACI,cAAA;AA3BR;AAoCA;EACI,cAAA;EACA,iCAAA;EACA,eAAA;AAlCJ;AAqCA;EACI,WAAA;EACA,YAAA;AAnCJ;AAsCA;EACI,WAAA;EACA,YAAA;EACA,YAAA;AApCJ;AAuCA;;;;;EAKI,kBAAA;AArCJ;AAwCA;EACI,YAAA;AAtCJ;AACA,mBAAmB;AAyCnB;EACI,gBAAA;EACA,mBAAA;EACA,uBAAA;EACA,WAAA;EACA,gCAAA;EACA,eAAA;EACA,cAAA;AAvCJ;AA0CA;EACI,WAAA;EACA,WAAA;EACA,yBAAA;AAxCJ;AA2CA;EACI,YAAA;EACA,yBAAA;AAzCJ;AA4CA;EACI,WAAA;EACA,aAAA;EACA,yBAAA;EACA,mBAAA;AA1CJ;AA8CI;EACI,gBAAA;AA5CR;AA+CI;EACI,iBAAA;AA7CR",sourcesContent:['.basicButtonStyle {\n    font-size: 12px;\n    padding: 6px 20px;\n    height: 28px;\n    line-height: 16px;\n}\n\n.actionButtonEnabled {\n    .basicButtonStyle;\n    border: none;\n\n    &:hover,\n    &:focus,\n    &:active:hover {\n        border: none;\n    }\n}\n\n.actionButtonDisabled {\n    .basicButtonStyle;\n    border: none;\n}\n\n.actionButtonSecondary {\n    .basicButtonStyle;\n    border: 1px solid;\n}\n\n.actionButtonWrapperBase {\n    margin-top: 8px;\n    display: flex;\n}\n\n.actionButtonWrapper {\n    .actionButtonWrapperBase;\n    justify-content: flex-end;\n}\n\n.centeredActionButtonWrapper {\n    .actionButtonWrapperBase;\n    justify-content: center;\n}\n\n.leftSideActionButtonWrapper {\n    .actionButtonWrapperBase;\n    justify-content: flex-start;\n}\n\n.secondaryActionButton {\n    .basicButtonStyle;\n}\n\n.commandButtonWrapper {\n    padding: 0;\n}\n\n.commandButtonStyle {\n    flex: auto;\n    height: 100%;\n    font-size: 12px;\n}\n\n.enabledCommandButtonStyle {\n    &:extend(.commandButtonStyle);\n    color: #212838;\n}\n\n.disabledCommandButtonStyle {\n    &:extend(.commandButtonStyle);\n}\n\n.enabledCommandButtonIcon {\n    color: #016677;\n}\n\n.disabledCommandButtonIcon {\n    color: inherit;\n}\n\n.insightCard {\n    margin: 18px 0px;\n    position: relative;\n    padding: 16px 16px;\n    border-radius: 8px;\n    box-shadow: 0 1.6px 3.6px 0 rgba(0, 0, 0, 0.132), 0 0.3px 0.9px 0 rgba(0, 0, 0, 0.108);\n}\n\n.inlineCard {\n    position: relative;\n    margin-top: 7px;\n    padding-top: 16px;\n}\n\n.incontextInsightCard {\n    .insightCard;\n    margin: 0;\n}\n\n.flexCard {\n    display: flex;\n}\n\n.flexCentered {\n    display: flex;\n    color: #4a4a4a;\n    align-items: center;\n}\n\n.spacedFlexWrapper {\n    display: flex;\n    color: #4a4a4a;\n    justify-content: space-between;\n    align-items: center;\n}\n\n.icon {\n    width: 40px;\n    height: 40px;\n}\n\n.paddedIcon {\n    width: 28px;\n    height: 28px;\n}\n\n.cardWrapper {\n    overflow: hidden;\n}\n\n.cardTitleWrapper {\n    display: flex;\n    align-items: center;\n    column-gap: 8px;\n}\n\n.cardTitle {\n    font-family: "Segoe UI Semibold";\n    font-size: 16px;\n    padding: 0px;\n    word-wrap: break-word;\n    overflow: hidden;\n}\n\n.cardDescription {\n    margin-top: 8px;\n    word-wrap: break-word;\n    font-family: "Segoe UI Regular";\n    font-size: 14px;\n}\n\n.iconButton {\n    &:hover {\n        font-weight: bolder;\n    }\n}\n\n.ChevronIcon {\n    .iconButton;\n    font-size: 8px;\n}\n\n.dismissButton {\n    position: absolute;\n    top: 0px;\n\n    [dir="ltr"] & {\n        right: 0px;\n    }\n\n    [dir="rtl"] & {\n        left: 0px;\n    }\n}\n\n.relativeButton {\n    position: relative;\n}\n\n.dismissIcon {\n    .iconButton;\n    font-size: 8px;\n    cursor: pointer;\n}\n\n.calloutDismissIcon {\n    font-size: 8px;\n    cursor: pointer;\n\n    &:hover {\n        font-weight: bolder;\n    }\n}\n\n.feedDismissIcon {\n    font-size: 8px;\n}\n\n.calendarIcon {\n    color: #018192;\n}\n\n.hr {\n    margin: 8px 0px;\n}\n\n.buttonWrapper {\n    margin: auto 0;\n    padding: 0;\n}\n\n.buttonWrapperBorderLess {\n    .buttonWrapper;\n}\n\n.toggleRoot {\n    margin: 0px;\n}\n\n.toggleColorAndSizeOn {\n    width: 40px;\n    height: 20px;\n}\n\n.toggleColorAndSizeOff {\n    width: 40px;\n    height: 20px;\n}\n\n.toggleText {\n    font-family: "Segoe UI Regular";\n    font-size: 14px;\n    align-self: center;\n\n    [dir="ltr"] & {\n        margin-left: 8px !important;\n        margin-right: 0px !important;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 0px !important;\n        margin-right: 8px !important;\n    }\n}\n\n.checkBoxText {\n    font-family: "Segoe UI Regular";\n    font-size: 14px;\n    line-height: normal;\n}\n\n// ----- Feed Card Styles below -----------\n// Will migrate into a single extensible \'card\' in the future.\n.cardContainer {\n    // Note: if any update in padding, change margin of [highlightImgWrapper] and [feedRightIconContainer] accordingly as well\n    padding: 16px;\n    margin: 18px 0;\n    border-radius: 8px;\n    box-shadow: 0 1.6px 3.6px 0 rgba(0, 0, 0, 0.132), 0 0.3px 0.9px 0 rgba(0, 0, 0, 0.108);\n\n    .highlightImgWrapper {\n        margin: -10px -10px 16px; // Negative values are computed from padding of [cardContainer] to ensure top/left/right margin of [highlightImgWrapper] to be 6px\n\n        .highlightImg {\n            display: block;\n            width: 100%;\n            height: 100%;\n        }\n    }\n\n    .feedRightIconContainer {\n        // Negative values are computed from padding of [cardContainer] to ensure right/left margin of [feedRightIconContainer] to be 6px\n        [dir="ltr"] & {\n            margin-right: -10px;\n        }\n\n        [dir="rtl"] & {\n            margin-left: -10px;\n        }\n\n        button {\n            outline: none !important;\n\n            div {\n                outline: none !important;\n            }\n        }\n    }\n}\n\n.closedDropdownCardContainer {\n    .cardContainer;\n    padding-bottom: 8px;\n}\n\n.clickableCard {\n    cursor: pointer;\n\n    // Elevate shadow to hover card\n    transition: box-shadow 0.2s ease;\n\n    &:hover {\n        box-shadow: 0 6.4px 14.4px 0 rgba(0, 0, 0, 0.132), 0 1.2px 3.6px 0 rgba(0, 0, 0, 0.108);\n    }\n}\n\n.verticalCenter {\n    height: 100%;\n    margin: auto 0;\n}\n\n.horizontalCenter {\n    display: flex;\n    justify-content: center;\n}\n\n.insightDescriptionContainer {\n    width: 100%;\n    word-wrap: break-word;\n    min-width: 0; //This is a flex child, need: https://css-tricks.com/flexbox-truncated-text/\n    font-size: 14px;\n    font-family: "Segoe UI Regular";\n}\n\n.leftIconContainer {\n    flex: 0 0 32px;\n\n    [dir="ltr"] & {\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n    }\n}\n\n.badge {\n    font-family: "Segoe UI Regular";\n    font-size: 10px;\n    line-height: 14px;\n    position: absolute;\n    top: -3px;\n    height: 14px;\n    min-width: 14px;\n    padding: 0 1px;\n    border-radius: 50%;\n    background-color: #ff0000;\n    color: #ffffff;\n    text-align: center;\n    transform: scale(0.833);\n\n    [dir="ltr"] & {\n        left: 6px;\n    }\n\n    [dir="rtl"] & {\n        right: 6px;\n    }\n}\n\n.clickable {\n    cursor: pointer;\n}\n\n.iconContainerStyle {\n    position: relative;\n    padding-top: 5px;\n}\n\n.rowContainer {\n    display: flex;\n    flex-direction: row;\n    width: 100%;\n}\n\n.rowCentered {\n    align-items: center;\n}\n\n.columnContainer {\n    display: flex;\n    flex-direction: column;\n    width: 100%;\n}\n\n.columnCentered {\n    align-items: center;\n    text-align: center;\n}\n\n.fullWidthContainer {\n    width: 100%;\n}\n\n.leftIcon {\n    align-self: flex-start;\n}\n\n.containsDismissIcon {\n    position: relative;\n}\n\n.autoGrowContainer {\n    flex: 1 1 auto;\n}\n\n.singleLine {\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n}\n\n.subject {\n    width: 100%;\n    color: #016677;\n    font-family: "Segoe UI Semibold";\n    word-wrap: break-word;\n\n    &:hover,\n    &:active:hover {\n        color: #004854;\n        text-decoration: underline;\n    }\n\n    &:focus {\n        color: #004854;\n    }\n}\n\n.singleLineSubject {\n    .singleLine;\n    .subject;\n}\n\n.defaultFont {\n    color: #4a4a4a;\n    font-family: "Segoe UI Semilight";\n    font-size: 12px;\n}\n\n.thumbSize {\n    width: 20px;\n    height: 20px;\n}\n\n.thumbStyle {\n    width: 22px;\n    height: 22px;\n    padding: 0px;\n}\n\n.buttonFocus:focus,\n.buttonWrapper:focus,\n.thumbStyle:focus,\n.toggleColorAndSizeOn:focus,\n.toggleColorAndSizeOff:focus {\n    outline: 1px solid;\n}\n\n.buttonWrapperBorderLess:focus {\n    outline: 0px;\n}\n\n/**Sent Email Card*/\n.sentEmailCardEmailStyle {\n    overflow: hidden;\n    white-space: nowrap;\n    text-overflow: ellipsis;\n    width: 100%;\n    font-family: "Segoe UI Semibold";\n    font-size: 12px;\n    color: #016677;\n}\n\n.openRateBar {\n    width: 100%;\n    height: 4px;\n    background-color: #ededed;\n}\n\n.openRateBarOpened {\n    height: 100%;\n    background-color: #016677;\n}\n\n.