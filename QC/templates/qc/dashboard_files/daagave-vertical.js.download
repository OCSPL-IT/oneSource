 0.5px 0.5px rgba(0, 0, 0, 0.2);\n    border: 1px solid #eaeaea;\n    border-radius: 10px;\n    // In Chrome, the insight cards may get stuck in the hover state when moving the mouse up and down quickly.\n    // The reason is the top-level mouseenter/mouseleave somehow not triggered when the underlying DOM node is updated.\n    // Workaround: Set descendant elements pointer-events to some other value(e.g "none") and keep parent elements\' default value "auto",\n    // then mouse events will trigger event listeners on the parent elements.\n    pointer-events: none;\n}\n\n.cardContainerStyle {\n    width: 100%;\n    height: @normalCardHeight;\n    display: inline-flex;\n    align-items: center;\n}\n\n.leftIconStyle {\n    flex: 0 0 45px;\n    height: 45px;\n    margin: auto 13.5px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n}\n\n.leftImageStyle {\n    width: 45px;\n    height: 45px;\n}\n\n.leftBroaderImageStyle {\n    width: 55px;\n    height: 55px;\n    margin: -10px;\n}\n\n.rightCardStyle {\n    flex: 1 1 auto;\n    display: inline-block;\n    display: -webkit-inline-box; // safari\n    -webkit-box-align: center; // vertical align in safari\n    overflow: hidden;\n    width: calc(100% - 90px);\n\n    [dir="ltr"] & {\n        margin-right: 24px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 24px;\n    }\n}\n\n.captionStyle {\n    width: 100%;\n    vertical-align: middle;\n    display: block;\n    line-height: 134%;\n}\n\n.confirmationCardStyle {\n    padding: 30px 0px;\n    text-align: center;\n    cursor: default;\n    animation: fade_in_and_out 1s infinite;\n}\n\n// surface cards are using padding-top for animations\n.dismissIconStyle {\n    position: absolute;\n    top: 10px + @cardPaddingTop;\n    right: 10px;\n    font-size: 9pt;\n    color: #212838;\n    cursor: pointer;\n}\n\n.dismissIconWithoutPaddingStyle {\n    &:extend(.dismissIconStyle);\n    top: 10px;\n}\n\n.sentStatsPercentageTitleStyle {\n    position: absolute;\n    top: 2px;\n    width: 62px;\n    font-size: 32px;\n    font-weight: 300;\n}\n\n.inContextBar {\n    margin-top: 10px;\n    display: flex;\n    align-items: center;\n    background-color: #f9f9f9;\n    border: 1px solid #f9f9f9;\n\n    [dir="ltr"] & {\n        padding-left: 10px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 10px;\n    }\n\n    &:hover {\n        border: 1px solid #64c8d8;\n        cursor: pointer;\n    }\n}\n\n.leftBar (@color: #EDF4F5) {\n    width: 4px;\n    flex: 0 0 4px;\n    background-color: @color;\n}\n\n.afterHoursLeftBar {\n    .leftBar();\n}\n\n.catchUpImportantMailLeftBar {\n    .leftBar(#34b1e2);\n}\n\n.dayMonthDateLabel {\n    color: #4a4a44;\n    font-size: "9pt";\n}\n.meetingOverloadStatus {\n    font-size: 8pt;\n    font-family: "Segoe UI Semibold";\n    color: #016677;\n}\n'],sourceRoot:""}]),n.locals={cardPadding:"YYimd_DvEoypDC88cN7S",cardBaseBox:"uEhrEzRVbSQn7nI8LJPw",cardBaseBoxShadow:"A5UQlFrj0qfzVJJ2hEuC",cardContainerStyle:"gPml26rmhBUz6fGdtC5o",leftIconStyle:"IqEz7uX2VX7lFX4zZwS4",leftImageStyle:"bmYMC5XaFHPFIXlDKDHM",leftBroaderImageStyle:"JTy4FMZtCCf524u6yaht",rightCardStyle:"oizdw9BLUrnikFojIp54",captionStyle:"wImvht2v69uVsZ9Lqy1j",confirmationCardStyle:"D8wP9pKmWwsshPB9UsJo",fade_in_and_out:"FpFTZ9VDTzSGeiOoVQ8A",dismissIconStyle:"V4q4B4wZTplCGSBfJZ33",dismissIconWithoutPaddingStyle:"eqgwwuBPU8Z3nhGDYzx7",sentStatsPercentageTitleStyle:"PfcY6A_V2wd26KbKVeFk",inContextBar:"PNXZiuypZYTbTwduOL_s",afterHoursLeftBar:"MKeP9jS4b4oqplIATLJ_",catchUpImportantMailLeftBar:"LR8YITVABxAqvwCyGcK9",dayMonthDateLabel:"JVnR_Z1otwzuoPiu9vKd",meetingOverloadStatus:"IKLdoxvwyZf0E4X9Bfos"},e.exports=n},19733:e=>{"use strict"
