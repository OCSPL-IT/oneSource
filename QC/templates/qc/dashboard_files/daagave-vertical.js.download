n.preparationSectionTitleStyle {\n    .sectionTitleStyle;\n    margin-bottom: 5px;\n}\n\n.sectionNameStyle {\n    display: flex;\n}\n\n.sectionNameTextStyle {\n    color: #254c5c;\n    font-size: 14px;\n}\n\n.sectionNameTextStyle:hover,\n.meetingSubject:hover {\n    text-decoration: underline;\n    cursor: pointer;\n}\n\n.attendeeNameText,\n.sectionValueTextStyle,\n.noAttendeeText,\n.preparationSection {\n    color: #212838;\n}\n\n.sectionValueTextStyle {\n    font-size: 14px;\n\n    [dir="ltr"] & {\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n    }\n}\n\n.seeDetailsSectionStyle {\n    cursor: pointer;\n    display: flex;\n    flex-direction: row;\n    justify-content: flex-end;\n}\n\n.seeDetailsTextStyle {\n    color: #1d7070;\n}\n\n.attendeeNameText,\n.attendeeStatusText,\n.seeDetailsIconStyle {\n    [dir="ltr"] & {\n        margin-left: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 5px;\n    }\n}\n\n.seeDetailsIconStyle {\n    height: 8px;\n    margin-top: 4px;\n}\n\n.sectionSeparationHorizontalBorderStyle,\n.itemSeparationHorizontalBorderStyle {\n    border: 1px solid #dedede;\n    border-bottom-style: none;\n    margin-bottom: 14px;\n}\n\n// Attendee section\n.attendeeSectionStyle {\n    display: flex;\n    align-items: center;\n    margin-bottom: 5px;\n}\n\n.attendeeCountContentsStyle,\n.attendeeBoxStyle {\n    display: flex;\n    align-items: center;\n}\n\n.attendeeNameText {\n    padding-top: 2px;\n}\n\n.attendeeBoxStyle {\n    flex: 1 1 auto;\n    flex-direction: column;\n}\n\n.attendeeCountTextStyle {\n    font-size: 32px;\n    color: #4db4b7;\n\n    [dir="ltr"] & {\n        margin-left: 10px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 10px;\n    }\n}\n\n.attendeeCountSubsectionTextStyle {\n    color: #858585;\n    margin-bottom: 7px;\n}\n\n// Overlay common\n.overlayContainer,\n.overlayContainerLastItem {\n    display: flex;\n    margin: 0px 5px;\n}\n\n.overlayContainer {\n    border-bottom: 1px solid #dedede;\n}\n\n.overlayNameSection {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    overflow: hidden;\n}\n\n.attendeeOverlaySection {\n    width: 100%;\n    margin-top: 10px;\n}\n\n// Attendee overlay\n.responseButtons {\n    margin: 10px 4px 4px 4px;\n}\n\n.notInViewResponseButton,\n.inViewResponseButton {\n    color: #666666;\n    cursor: pointer;\n}\n\n.inViewResponseButton {\n    border-bottom: 3px solid #71d8bf;\n}\n\n.attendeeStatusText {\n    color: #666666;\n    font-size: 10px;\n}\n\n.attachmentTypeText,\n.importantPersonIcon {\n    [dir="ltr"] & {\n        margin-left: 3px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 3px;\n    }\n}\n\n.importantPersonIcon {\n    width: 20px;\n    height: 20px;\n}\n\n.noAttendeeText {\n    text-align: center;\n    margin: 20px;\n}\n\n.attendeeOverlayIcon,\n.attachmentOverlayIcon {\n    flex: 0 0 28px;\n    height: 28px;\n}\n\n.attendeeOverlayIcon {\n    [dir="ltr"] & {\n        margin: 10px 5px 10px 0px;\n    }\n\n    [dir="rtl"] & {\n        margin: 10px 0px 10px 5px;\n    }\n}\n\n// Attachment overlay\n.attachmentTypeSection {\n    display: flex;\n}\n\n.attachmentTypeText {\n    color: rgba(33, 40, 56, 0.69);\n}\n\n.attachmentActionsText {\n    color: #1d627e;\n}\n\n.attachmentItemSection {\n    display: flex;\n    justify-content: space-between;\n    width: 100%;\n}\n\n.attachmentActionSection {\n    align-items: center;\n    cursor: pointer;\n    display: flex;\n    flex: none;\n}\n\n.attachmentActionButtonStyle {\n    width: 14px;\n\n    [dir="ltr"] & {\n        margin: 0px 5px 0px 20px;\n    }\n\n    [dir="rtl"] & {\n        margin: 0px 20px 0px 5px;\n    }\n}\n\n.attachmentNameText {\n    .hideOverflow;\n    color: #016677;\n}\n\n.attachmentNameSection {\n    display: flex;\n    overflow: hidden;\n    flex: 1;\n}\n\n.attachmentOverlayIcon {\n    [dir="ltr"] & {\n        margin: 10px 5px 10px 0px;\n    }\n\n    [dir="rtl"] & {\n        margin: 10px 0px 10px 5px;\n    }\n}\n\n.attachmentTypeIcon {\n    height: 12px;\n    align-self: center;\n}\n\n// Preparation Section\n.preparationSection,\n.noPreparationTimeString {\n    margin-top: 8px;\n}\n\n.disabledPreparationTimeButton,\n.pendingPreparationTimeButton,\n.bookPreparationTimeButton,\n.unbookPreparationTimeButton {\n    align-items: center;\n    justify-content: center;\n    display: flex;\n    width: 111px;\n    padding: 12px 10px 12px 10px;\n}\n\n.bookPreparationTimeButton,\n.unbookPreparationTimeButton {\n    cursor: pointer;\n}\n\n.bookPreparationTimeButton {\n    background-color: rgba(237, 244, 245, 0.5);\n}\n\n.bookPreparationTimeButton:hover,\n.unbookPreparationTimeButton:hover {\n    background-color: #eaf3e0;\n    color: #25667a;\n}\n\n.unbookPreparationTimeButton {\n    background-color: #d4e79c;\n}\n\n.disabledPreparationTimeButton {\n    background-color: #f3f2f1;\n    color: #a19f9d;\n}\n\n.pendingPreparationTimeButton {\n    background-color: #eaf3e0;\n}\n\n.noPreparationTimeString {\n    white-space: normal;\n    word-break: break-word;\n}\n\n.preparationTimeButtonText {\n    .hideOverflow;\n    text-align: center;\n}\n\n.noMeetingsFound {\n    margin: 4px 0;\n}\n\n.dateHeaderStyle {\n    font-family: Segoe UI Semibold;\n    font-size: 14px;\n    line-height: 30px;\n    min-height: 30px;\n    color: #333333;\n    position: -webkit-sticky;\n    position: sticky;\n    top: 0;\n    z-index: 4;\n    padding: 2px;\n    margin-right: -3px;\n    margin-left: -3px;\n}\n\n.dateHeaderStyleBackground {\n    line-height: 30px;\n    min-height: 30px;\n    position: sticky;\n    top: 0;\n    z-index: 3;\n}\n\n.nextPrevWeekLabelSectionStyle {\n    display: flex;\n\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.nextPrevWeekLabelStyle {\n    .nextPrevWeekLabelSectionStyle;\n\n    font-family: Segoe UI Semibold;\n    font-size: 14px;\n    line-height: 19px;\n\n    &:hover {\n        text-decoration: underline;\n    }\n}\n\n.nextPrevWeekIconStyle {\n    width: 16px;\n    height: 16px;\n    line-height: 19px;\n}\n\n.prevWeekIconStyle {\n    .nextPrevWeekIconStyle;\n\n    [dir="ltr"] & {\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n    }\n}\n\n.nextWeekIconStyle {\n    .nextPrevWeekIconStyle;\n\n    [dir="ltr"] & {\n        margin-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 8px;\n    }\n}\n'],sourceRoot:""}]),n.locals={hideOverflow:"YHqRM9A9k2WteNdrXrXQ",cardWrapper:"m4GyHuD2KgMvDW_B2aqL",timeLabel:"y5d8ZQQt_YWPBAQ7rNJb",meetingSubject:"q4Q8hVcC_cSVGurJwHTc",inViewResponseButton:"nsnIsn7w_8e64KrPG_2A",sectionNameTextStyle:"yvoIow5mZzWyyHQg6W8f",invitedCountIconStyle:"uILGlOvOd9mZVziatkmq",acceptedPercentIconStyle:"yUzDghnATvJMhtd_J6bN",preparationSection:"gz_RiGJrOj776Nw98nlY",sectionTitleStyle:"P5ogTgAxpihPjOHfMaG5",responseButtons:"vUt49zFIRqL6rWbbV4fK",lastSectionTitleStyle:"wjpF3n7ARU8iwH6o84Sv",attendeeSectionTitleStyle:"Mvc_4zxwWZBRAukXC8TR",preparationSectionTitleStyle:"qBWOe9UAzIHy7KUfOoH5",sectionNameStyle:"pasoHa9lDQfQxdi2S9hm",attendeeNameText:"syNtcFDpJyIG1jrLNssB",sectionValueTextStyle:"jLtx6e2FYFf3ovBNutru",noAttendeeText:"VEGLwcHzYn3DRjQT_BBC",seeDetailsSectionStyle:"Tm9K_c6yInlGkUFgLbeF",seeDetailsTextStyle:"fTVA1hLtj7dR4_7vuQeH",attendeeStatusText:"vUodbkg7tcVdhI4SLmev",seeDetailsIconStyle:"k1uX0pj5cG11aU9cpReW",sectionSeparationHorizontalBorderStyle:"XLmzhb5tqXEDRBim0rYe",itemSeparationHorizontalBorderStyle:"zXC94Yh6e7_E4Bs7dXo4",attendeeSectionStyle:"tbjQu1UNWj5JZ_6hM73x",attendeeCountContentsStyle:"fva2eSO_eoJN220ebV2S",attendeeBoxStyle:"nKI790QoWxDkz7Z51Qv_",attendeeCountTextStyle:"pNqthSl8DiU99zwMfM14",attendeeCountSubsectionTextStyle:"iURzLDsCke8J2YQ4Yraf",overlayContainer:"Hq_Rw58SVJtDIbYPfLRc",overlayContainerLastItem:"EPHwUzLWMQE4x_oXqLCg",overlayNameSection:"gSaaE048RuS52Wk4g1yL",attendeeOverlaySection:"Xh7to4CcheKYP2tEbDHA",notInViewResponseButton:"FkGbX3LuaELoUiNwhGhj",attachmentTypeText:"eXqGwByUDHejaxsLkh0P",importantPersonIcon:"zrAX5C6msXQ