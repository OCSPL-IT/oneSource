ize: 12px;\n}\n\n.calloutSize {\n    width: 250px;\n}\n\n.calloutContent {\n    font-size: 14px;\n\n    &WithTopPadding {\n        padding-top: 14px;\n    }\n}\n\n.calloutHeader {\n    font-family: "Segoe UI Semibold";\n    font-size: 16px;\n}\n\n.calloutStyles {\n    padding: 14px;\n}\n\n.calloutWrapper {\n    color: #ffffff;\n}\n\n.recipientsTimeZoneSlotsContainer {\n    font-size: 12px;\n    padding: 10px 0;\n}\n\n.slotTitle {\n    padding-top: 10px;\n    padding-bottom: 4px;\n}\n\n.slotContent {\n    margin: 2px 0;\n    padding: 4px 7px;\n    background-color: #f0f0f0;\n}\n\n.plusMore {\n    cursor: pointer;\n    border-radius: 2px;\n}\n\n.plusMoreContainer {\n    font-size: 12px;\n    padding-top: 10px;\n}\n\n.dateTimePickerContainer {\n    .flexContainer;\n    margin-top: 14px;\n    justify-content: space-between;\n}\n\n.datePicker {\n    width: 50%;\n    min-width: 112px;\n    height: 32px;\n}\n\n.timePicker {\n    width: 50%;\n    min-width: 112px;\n    height: 32px;\n\n    [dir="ltr"] & {\n        padding-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 8px;\n    }\n}\n\n.recipientsLocalTimeSection {\n    margin: 18px 0;\n}\n\n.recipientsLocalTimeTitle {\n    font-size: 12px;\n    font-weight: 600;\n    line-height: 16px;\n    margin-bottom: 8px;\n}\n\n.recipientsLocalTimeRow {\n    margin-bottom: 16px;\n}\n\n.avatarRow {\n    position: relative;\n    margin-bottom: 4px;\n}\n\n.recipientLocalTime {\n    font-size: 12px;\n    line-height: 16px;\n    font-weight: 400;\n    margin-left: 18px;\n    position: absolute;\n    top: 0;\n\n    [dir="ltr"] & {\n        left: 37%;\n    }\n\n    [dir="rtl"] & {\n        right: 44%;\n    }\n}\n\n.workingHoursOuterContainer {\n    width: 100%;\n    height: 8px;\n    overflow: hidden;\n    position: relative;\n}\n\n.workingHoursInnerContainer {\n    display: flex;\n    height: inherit;\n    width: 200%;\n}\n\n.workingHoursBar {\n    height: inherit;\n    width: 50%;\n    border-radius: 4px;\n    background-color: #edebe9;\n}\n\n.workingHoursHighlight {\n    height: inherit;\n    border-radius: 4px;\n    background-color: #a7c7ff;\n}\n\n.deliveryTimeSlot {\n    width: 2px;\n    height: 8px;\n    background-color: #6ca2ff;\n    position: absolute;\n    left: calc(50% - 1px);\n    top: 0;\n}\n\n.showMoreButton {\n    display: flex;\n    align-items: baseline;\n    border: none;\n    padding: 0;\n    background-color: transparent;\n    cursor: pointer;\n    margin: -7px auto 0;\n}\n\n.showMoreText {\n    line-height: 16px;\n    font-size: 12px;\n    font-weight: 400;\n    font-family: "Segoe UI";\n}\n\n.learnMoreLink {\n    margin: auto 12px;\n    padding: 6px 0;\n    border: none;\n    border-radius: 2px;\n    font-size: 14px;\n    font-weight: 400;\n    font-family: "Segoe UI Regular";\n\n    &:focus {\n        text-decoration: underline;\n    }\n}\n\n.delayDeliveryLearnMoreLink {\n    margin-top: 20px;\n}\n\n.learnMoreText {\n    font-size: 14px;\n    line-height: 20px;\n    text-decoration: underline;\n}\n\n.chevronIcon {\n    [dir="ltr"] & {\n        margin-left: 6px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 6px;\n    }\n\n    font-size: 8px;\n}\n\n.autoScheduleSendFooterWrapper {\n    display: flex;\n    flex-direction: column;\n}\n\n.autoScheduleSendTipWrapper {\n    display: flex;\n    align-items: center;\n}\n\n.autoScheduleSendTitle {\n    font-family: "Segoe UI";\n    font-size: 16px;\n    font-weight: 600;\n    line-height: 22px;\n}\n\n.autoScheduleSendTipLabel {\n    font-family: "Segoe UI";\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 20px;\n}\n\n.autoScheduleSendTipIcon {\n    .tipIcon;\n\n    height: 12px;\n}\n\n.autoScheduleSendToggle {\n    display: flex;\n    justify-content: flex-end;\n    margin-top: 8px;\n}\n\n.hr {\n    margin-top: 16px;\n}\n'],sourceRoot:""}]),n.locals={flexContainer:"AEZDszd9rRy93wxO4IWK",insightCard:"iG5T2gGtZ68G2NeLfxjU",confirmCardTitle:"jQkGBRLHl3X5jlj68TBx",editCardTitle:"HV3SA87z9PwQqEtIgcEX",ic