ingIcon {\n    position: absolute;\n    color: #797775;\n    width: 16px;\n    height: 16px;\n}\n\n.warningSection {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n}\n\n.chevronIcon {\n    [dir="ltr"] & {\n        padding-left: 6px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 6px;\n    }\n    font-size: 8px;\n    margin: auto;\n}\n\n.conflictSection {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 32px;\n    background: #fff4ce;\n    padding: 4px;\n    display: flex;\n    flex-direction: row;\n    align-items: flex-start;\n    width: 100%;\n}\n\n.conflictSectionMargin {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    top: 4px;\n    width: calc(100% - 16px); // subtract warningIcon width\n}\n\n.conflictSectionHeading {\n    font-weight: 600;\n    color: #323130;\n    line-height: 16px;\n    size: 12px;\n}\n\n.conflictMeetingRow {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 4px;\n    width: 100%;\n}\n\n.conflictMeetingSubject {\n    .hideOverflow;\n    font-family: Segoe UI;\n    font-size: 12px;\n    line-height: 16px;\n    font-weight: 400;\n    color: #296575;\n    max-width: 125px;\n\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n.conflictMeetingDuration {\n    font-family: Segoe UI;\n    font-size: 12px;\n    line-height: 16px;\n    font-weight: 400;\n    color: #797775;\n    text-align: right;\n}\n\n.outOfRoutineSectionGeneral {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 16px;\n    white-space: normal;\n    width: 230px;\n}\n\n.outOfRoutineSectionText {\n    .outOfRoutineSectionGeneral;\n    color: #323130;\n    top: 4px;\n    left: 28px;\n}\n\n.outOfRoutineSectionMargin {\n    padding: 4px;\n    display: flex;\n    flex-direction: row;\n    align-items: flex-start;\n    background: #fff4ce;\n}\n\n.preparationSection {\n    margin-top: 16px;\n    margin-bottom: 16px;\n}\n\n// Accept meeting section\n.acceptText {\n    font-weight: 400;\n    font-size: 14px;\n    line-height: 20px;\n}\n\n.loadingStatusWithIcon {\n    .coloredText;\n    .acceptText;\n    display: flex;\n    flex-direction: row;\n    align-items: flex-start;\n    margin-top: 8px;\n    width: 262px;\n    height: 20px;\n}\n\n.checkIcon {\n    width: 12px;\n    height: 12px;\n\n    [dir="ltr"] & {\n        margin-right: 10px;\n    }\n    [dir="rtl"] & {\n        margin-left: 10px;\n    }\n}\n\n.doneStatusWithIcon {\n    .loadingStatusWithIcon;\n    color: #13a10e;\n}\n\n.acceptErrorCard {\n    display: flex;\n    margin: 16px 0px;\n    position: relative;\n    [dir="ltr"] & {\n        padding: 4px 8px 4px 4px;\n    }\n\n    [dir="rtl"] & {\n        padding: 4px 4px 4px 8px;\n    }\n\n    color: #323130;\n    background: #fff4ce;\n}\n\n.errorSectionText {\n    width: 250px;\n    height: 48px;\n    font-family: Segoe UI;\n    font-size: 12px;\n    line-height: 16px;\n    font-weight: 400;\n    [dir="ltr"] & {\n        padding-left: 8px;\n    }\n    [dir="rtl"] & {\n        padding-right: 8px;\n    }\n}\n'],sourceRoot:""}]),n.locals={hideOverflow:"tPBB4V5bsJzJP5PN76pp",cardWrapper:"qsgGaV6nLki3oyxP8CqM",floatChildrenCenter:"ffzOAZjEPG7RKLUvC41C",hoverEffect:"NeIAbd9tHEYK7z5CWDQE",loadDetailsContainer:"j_KzlTTLKf11KizBoNq_",loadDetails:"Sk12U87stHu_otuVuy_u",separatorStyle:"GzHPcFHW8dSY6yvfXigY",hideDetailsContainer:"Sy2RLxdtdoTixYCb7vxr",viewDetailsContainer:"e8oJA3D3t7faLYHFWHTZ",detailsContainer:"iETkOR6GMX9oJctVrXUA",coloredText:"d6f05K0UnJQzDHaeN3HL",viewDetails:"GCqzBxZt0hytZXl1lyCo",detailsContainerHideDisplayButton:"nakjLM9kUaFJeZxl574j",warning:"fLb8Am_BngoVglEitgSn",warningIcon:"cfF4TSznzDSnCzWcI2Cg",warningSection:"Dq35nuyGsGSmap_nLYN6",chevronIcon:"oMCmDCA_5sE64bTUHpjx",conflictSection:"uAY9DKwbUz1apxofVmdd",conflictSectionMargin:"zS_FXErJ8coMJ8aheBfc",conflictSectionHeading:"PhsyBahsb1bSZjZzTKEW",conflictMeetingRow:"U8PPSKvB3S1NL2R4lu_3",conflictMeetingSubject:"rMYaLLDOcPFuNMYylRKw