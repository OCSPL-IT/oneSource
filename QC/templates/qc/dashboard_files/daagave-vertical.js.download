     margin-left: 1px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 1px;\n    }\n}\n\n.showMoreIcon {\n    font-size: 0.85em; // width and height do not affect icon size, but font-size does.\n}\n\n.preparationTimeInformationCard {\n    background: rgba(19, 161, 14, 0.1);\n    border-radius: 2px;\n    width: 252px;\n    height: 46px;\n    display: flex;\n    align-items: flex-start;\n    flex-direction: row;\n    margin-top: 16px;\n\n    &:hover .deletePreparationTimeButton,\n    &:active:hover .deletePreparationTimeButton {\n        display: block;\n\n        &:hover .deleteIcon,\n        &:active:hover .deleteIcon {\n            color: #d83b01;\n        }\n    }\n}\n\n.icon {\n    width: 15px;\n    height: 15px;\n}\n\n.checkIcon {\n    .icon;\n    margin: 10px 10px 25px 10px;\n    color: #13a10e;\n}\n\n.preparationTimeInformationText {\n    margin-top: 8px;\n}\n\n.preparationTimeHeader {\n    font-weight: 600;\n    font-size: 12px;\n    line-height: 16px;\n    color: #13a10e;\n\n    width: 98px;\n    height: 16px;\n}\n\n.preparationTimeRangeInformation {\n    font-weight: 400;\n    font-size: 10px;\n    line-height: 12px;\n    color: #13a10e;\n\n    margin-top: 3px;\n}\n\n.deletePreparationTimeButton {\n    margin-top: auto;\n    margin-bottom: auto;\n\n    &:hover,\n    &:active:hover {\n        background: #fcf2f3;\n    }\n\n    [dir="ltr"] & {\n        margin-left: auto;\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n        margin-right: auto;\n    }\n\n    display: none;\n}\n\n.deleteIcon {\n    .icon;\n    color: #605e5c;\n\n    &:hover,\n    &:active:hover {\n        color: #d83b01;\n    }\n}\n\n.dropdownHorizontalArrow {\n    font-size: 0.85em; // width and height do not affect icon size, but font-size does.\n    color: #323130;\n\n    [dir="rtl"] & {\n        transform: scale(-1);\n    }\n}\n\n.preparationTimeWaitingForDelete {\n    margin-top: 16px;\n}\n\n// Error card section\n.preparationTimeInformationErro