ked {\n    .cardStyle;\n    background-color: #c9e7aa;\n}\n\n.cardStyle_notBooked {\n    .cardStyle;\n    background-color: #eef6f9;\n}\n\n.cardStyle_edit {\n    .cardStyle;\n    background-color: #ffffff;\n    border: 1px solid #c9e7aa;\n}\n\n.subjectStyle {\n    display: flex;\n    height: 100%;\n    flex: 1 1 100px;\n    overflow: hidden;\n\n    [dir="ltr"] & {\n        margin-right: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 5px;\n    }\n}\n\n.subjectTextStyle {\n    text-overflow: ellipsis;\n    overflow: hidden;\n    white-space: nowrap;\n    line-height: 32px;\n    font-size: 12px;\n}\n\n.editIconWrapper {\n    display: flex;\n    width: 21px;\n}\n\n.timeStyle {\n    font-family: "Segoe UI Semilight";\n    font-size: 12px;\n    flex: 1 1 120px;\n}\n\n.actionWrapper {\n    flex: 1 0 32px;\n}\n\n.actionStyle,\n.actionStyle:hover,\n.editIconStyle,\n.editIconStyle:hover {\n    background-color: transparent;\n}\n\n.editIconStyle {\n    transform: scale(0.8, 0.8);\n}\n\n// Focus Subject Input\n\n.textFieldStyle {\n    flex: 1 1 200px;\n\n    [dir="ltr"] & {\n        margin-right: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 5px;\n    }\n}\n\n.checkIconStyle {\n    .actionStyle;\n}\n\n// Loading Icon\n\n.loadingIconStyle {\n    padding: 6px;\n}\n\n// Protected Time Header\n\n.containerStyle {\n    padding-top: 12px;\n    padding-bottom: 40px;\n}\n\n.flexStyle {\n    display: flex;\n}\n\n.titleStyle {\n    font-family: "Segoe UI Semibold";\n    font-size: 12px;\n}\n\n.bodyStyle {\n    font-family: "Segoe UI Semilight";\n    font-size: 12px;\n    padding: 7px 0px;\n}\n\n.imagePadding {\n    [dir="ltr"] & {\n        padding-right: 14px;\n    }\n\n    [dir="rtl"] & {\n        padding-left: 14px;\n    }\n}\n\n.protectedTimeHeaderImage {\n    width: 52px;\n    height: 55px;\n}\n\n.bookAllStyle {\n    flex: 1;\n\n    [dir="ltr"] & {\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n    }\n}\n\n.centerIconWrapper