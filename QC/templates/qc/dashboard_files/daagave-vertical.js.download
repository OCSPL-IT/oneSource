R;AA0EA;EACI,iBAAA;EACA,aAAA;AAxEJ;AA2EA;EACI,6BAAA;EACA,eAAA;EACA,iBAAA;EACA,mBAAA;EACA,mBAAA;EACA,kBAAA;EACA,cAAA;EACA,YAAA;EACA,gBAAA;AAzEJ;AA4EA;EAnCI,6BAAA;EACA,eAAA;EACA,iBAAA;EACA,mBAAA;EAkCA,cAAA;AAvEJ;AAwEI;EACI,iBAAA;EACA,kBAAA;AAtER;AAyEI;EACI,iBAAA;EACA,kBAAA;AAvER;AA2EA;EACI,aAAA;EACA,8BAAA;EACA,eAAA;EACA,iBAAA;AAzEJ;AA4EA;EAQI,cAAA;EACA,iBAAA;AAjFJ;AAyEI;EACI,yBAAA;AAvER;AA0EI;EACI,yBAAA;AAxER;AA4EI;EAxjBA,0BAAA;EACA,eAAA;AA+eJ",sourcesContent:['.hideOverflow {\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n}\n\n.floatChildrenRight {\n    display: flex;\n    justify-content: flex-end;\n}\n\n.hoverEffect {\n    text-decoration: underline;\n    cursor: pointer;\n}\n\n.sectionTitleStyleWithoutBorder {\n    .sectionTitleStyle;\n    padding-top: 12px;\n}\n\n.sectionTitleStyleWithBorder {\n    .sectionTitleStyleWithoutBorder;\n    .sectionSeparationHorizontalBorderStyle;\n}\n\n// sections - general\n.sectionNameTextStyle {\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 18px;\n    color: #323130;\n}\n\n.sectionSeparationHorizontalBorderStyle {\n    border-top: 1px solid #f2f2f2;\n}\n\n.sectionTitleStyle {\n    display: flex;\n    justify-content: space-between;\n}\n\n.attendeeSectionTitleStyle,\n.preparationSectionTitleStyle {\n    .sectionTitleStyle;\n    .sectionSeparationHorizontalBorderStyle;\n    padding-top: 16px;\n}\n\n// organizer and meeting info section\n.topSection {\n    display: flex;\n    flex-direction: row;\n    margin: 8px 0px 16px;\n}\n\n.organizerOverlayIcon {\n    flex: 0 0 28px;\n    height: 28px;\n\n    [dir="ltr"] & {\n        margin: 0px 5px 10px 0px;\n    }\n\n    [dir="rtl"] & {\n        margin: 0px 0px 10px 5px;\n    }\n}\n\n.organizerPhoto {\n    float: left;\n    width: 34px;\n\n    [dir="ltr"] & {\n        margin-right: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 8px;\n    }\n}\n\n.meetingDetails {\n    min-width: 0;\n    width: 100%;\n}\n\n.meetingSubject {\n    font-family: Segoe UI Semibold;\n    font-size: 14px;\n    line-height: 20px;\n    width: 100%;\n    color: #016677;\n\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n.organizerName {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 18px;\n}\n\n.timeLabel {\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 18px;\n}\n\n.startTimeDurationAndLocationSection {\n    display: flex;\n    justify-content: space-between;\n}\n\n.locationLabel {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 18px;\n    max-width: 100px;\n}\n\n.viewDetailsContainerWithoutBorder {\n    .floatChildrenRight;\n    line-height: 18px;\n    padding: 12px 0px;\n}\n\n.viewDetailsContainer {\n    .sectionSeparationHorizontalBorderStyle;\n    .viewDetailsContainerWithoutBorder;\n}\n\n.viewDetailsContainerShort {\n    .viewDetailsContainer;\n    padding: 12px 0px 0px;\n    margin-top: 12px;\n}\n\n.coloredText {\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    color: #1d7070;\n}\n\n.viewDetails {\n    .coloredText;\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n.sectionContainer {\n    margin-top: 12px;\n    height: 32px;\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n}\n\n.sectionValue {\n    .coloredText;\n    [dir="ltr"] & {\n        margin-right: 12px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 12px;\n    }\n}\n\n.viewMeetingDetailsIcon {\n    height: 20px;\n}\n\n// conflicting meetings summary / details sections\n.conflictSectionShort,\n.conflictSectionLong {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 32px;\n    background: #fff4ce;\n    letter-spacing: -0.24px;\n    margin-top: 12px;\n}\n\n.conflictSectionShort {\n    display: flex;\n    margin-top: 12px;\n    line-height: 32px;\n}\n\n.conflictSectionHeading {\n    font-weight: bolder;\n    color: #4a4a4a;\n}\n\n.conflictSectionDetailsShort {\n    color: #296575;\n    [dir="ltr"] & {\n        margin-left: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 5px;\n    }\n}\n\n.conflictIcon {\n    font-size: 16px;\n    margin: 0px 8px;\n    color: #4a4a4a;\n}\n\n.conflictSectionLongHeading {\n    line-height: 32px;\n    display: flex;\n}\n\n.conflictingMeetingRow {\n    display: flex;\n    justify-content: space-between;\n}\n\n.conflictingMeetingSubject {\n    .hideOverflow;\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 18px;\n    color: #296575;\n    max-width: 125px;\n    margin-bottom: 6px;\n\n    [dir="ltr"] & {\n        margin-left: 10px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 10px;\n    }\n\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n.conflictingMeetingDuration {\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 18px;\n    color: #4a4a4a;\n\n    [dir="ltr"] & {\n        margin-right: 9px;\n        margin-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 9px;\n        margin-right: 8px;\n    }\n}\n\n// Attendee section\n.attendeeSectionStyle {\n    display: flex;\n    margin-top: 12px;\n}\n\n.attendeeSummarySectionStyle {\n    .sectionTitleStyleWithoutBorder;\n    margin-top: 12px;\n}\n\n.attendeeBoxStyle {\n    display: flex;\n    flex-direction: column;\n\n    [dir="ltr"] & {\n        margin-right: 20px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 20px;\n    }\n}\n\n.attendeeRightAlignedBoxStyle {\n    flex-direction: column;\n    margin-top: auto;\n    flex-grow: 1;\n}\n\n.attendeeCountTextStyle {\n    display: flex;\n    font-family: Segoe UI Semibold;\n    font-size: 16px;\n    line-height: 22px;\n    color: #4a4a4a;\n}\n\n.attendeeCountSubsectionTextStyle {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 16px;\n    color: #4a4a4a;\n}\n\n.inViewResponseButton {\n    font-family: Segoe UI Semibold;\n    color: #1d7070;\n    padding-bottom: 4px;\n    border-bottom: 2px solid #1d7070;\n}\n\n.notInViewResponseButton {\n    font-family: Segoe UI Regular;\n    color: #999999;\n    cursor: pointer;\n}\n\n.overlayContainer {\n    display: flex;\n    margin: 0px 5px;\n}\n\n// meeting response section\n.respondSection {\n    background: #f3f2f1;\n    margin: 12px 0px;\n    display: flex;\n}\n\n.respondSectionTitle {\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 16px;\n    color: #323130;\n    margin: 8px 12px;\n}\n\n.respondSectionActions {\n    .respondSectionTitle;\n    display: flex;\n    align-content: flex-end;\n\n    [dir="ltr"] & {\n        margin-left: auto;\n    }\n\n    [dir="rtl"] & {\n        margin-right: auto;\n    }\n}\n\n.respondSectionIndividualAnswers {\n    color: #1d7070;\n\n    [dir="ltr"] & {\n        margin-left: 12px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 12px;\n    }\n\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n// Attachments\n.attachmentEntry {\n    margin-bottom: 12px;\n}\n\n.attachmentsSectionStyle {\n    margin: 24px 0px 12px;\n}\n\n.attachmentIconSection {\n    display: flex;\n    width: 32px;\n}\n\n.attachmentNameText {\n    .hideOverflow;\n    color: #016677;\n    line-height: 16px;\n    font-size: 12px;\n    font-family: Segoe UI Semibold;\n    max-width: 180px;\n\n    &:hover {\n        .hoverEffect;\n    }\n}\n\n.attachmentIcon {\n    flex: 0 0 16px;\n    height: 16px;\n\n    [dir="ltr"] & {\n        margin-left: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 5px;\n    }\n}\n\n.defaultFileIconStyle {\n    color: #b5b5b5;\n    font-size: 15px;\n    [dir="ltr"] & {\n        margin-left: 7px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 7px;\n    }\n}\n\n.cloudIcon {\n    position: relative;\n    z-index: 2;\n    height: 12px;\n    top: 6px;\n\n    [dir="ltr"] & {\n        left: -10px;\n    }\n\n    [dir="rtl"] & {\n        right: -10px;\n    }\n}\n\n// related tasks and documents\n.attachmentSection {\n    display: flex;\n    align-items: center;\n}\n\n.attachmentDismissSection {\n    [dir="ltr"] & {\n        margin-left: auto;\n    }\n\n    [dir="rtl"] & {\n        margin-right: auto;\n    }\n}\n\n.attachmentDismissIcon {\n    position: relative;\n    height: 24px;\n}\n\n.relatedAttachmentsContainer {\n    padding-bottom: 12px;\n}\n\n.relatedTasksAndDocumentsSectionStyle {\n    .sectionSeparationHorizontalBorderStyle;\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 18px;\n    display: flex;\n    padding: 7px 0px;\n}\n\n.relatedTasksAndDocumentsSectionExpandedStyle {\n    padding-bottom: 0px;\n}\n\n// Out of routine section\n\n.outOfRoutineSectionLongAttendee {\n    line-height: 32px;\n}\n\n.outOfRoutineSectionShortAttendeeShortMargin,\n.outOfRoutineSectionShortAttendeeLongMargin {\n    line-height: 32px;\n    display: flex;\n}\n\n.outOfRoutineSectionShortAttendeeShortMargin {\n    margin-top: 4px;\n}\n\n.outOfRoutineSectionLongAttendee,\n.outOfRoutineSectionShortAttendeeLongMargin {\n    margin-top: 12px;\n}\n\n.outOfRoutineSectionLongAttendee,\n.outOfRoutineSectionShortAttendeeShortMargin,\n.outOfRoutineSectionShortAttendeeLongMargin {\n    background: #fff4ce;\n}\n\n.outOfRoutineIcon {\n    font-size: 16px;\n    margin: 4px 8px;\n    color: #797775;\n    vertical-align: top;\n}\n\n.outOfRoutineSectionGeneral {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 18px;\n    white-space: normal;\n}\n\n.outOfRoutineSectionText {\n    .outOfRoutineSectionGeneral;\n    color: #4a4a4a;\n    [dir="ltr"] & {\n        margin: 10px 10px 13px 0px;\n    }\n\n    [dir="rtl"] & {\n        margin: 10px 0px 13px 10px;\n    }\n}\n\n.outOfRoutineSectionLongHeading {\n    line-height: 32px;\n    display: flex;\n}\n\n.noResponseRequestedSection {\n    font-family: Segoe UI Regular;\n    font-size: 12px;\n    line-height: 16px;\n    white-space: normal;\n    background: #f3f2f1;\n    border-radius: 2px;\n    color: #323130;\n    padding: 8px;\n    margin-top: 12px;\n}\n\n.outOfRoutineLongOrgText {\n    .outOfRoutineSectionGeneral;\n    color: #4a4a4a;\n    [dir="ltr"] & {\n        margin-left: 31px;\n        margin-right: 41px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 41px;\n        margin-right: 31px;\n    }\n}\n\n.outOfRoutineRespondSection {\n    display: flex;\n    font-family: Segoe UI Semibold;\n    font-size: 12px;\n    line-height: 16px;\n}\n\n.outOfRoutineRespondAction {\n    [dir="ltr"] & {\n        margin: 2px 12px 8px auto;\n    }\n\n    [dir="rtl"] & {\n        margin: 2px auto 8px 12px;\n    }\n    color: #1d7070;\n    text-align: right;\n    &:hover {\n        .hoverEffect;\n    }\n}\n'],sourceRoot:""}]),n.locals={hideOverflow:"caeC5Zd1Ar4uv4QcqCAZ",floatChildrenRight:"idY61pmHyadG_HkGwy27",hoverEffect:"hEHOHth8wi0spUKlNDDg",sectionTitleStyleWithoutBorder:"CrYDfseAqxKw2hKBh7QO",sectionTitleStyleWithBorder:"m8qD4Z_goOrNIMJ4pVqe",sectionNameTextStyle:"en8IxGVVGIs5acKI8zf2",sectionSeparationHorizontalBorderStyle:"X9GMpKySiQ9OR5KQeAis",sectionTitleStyle:"oTSAvFjTHWVKCbHl18Sc",attendeeSectionTitleStyle:"ALBAOHKK7rPuuVHHkd2w",preparationSectionTitleStyle:"w_22pw9l7GgdGP5rN6Mw",topSection:"M_vBMkeSgCpC0kcWEtoO",organizerOverlayIcon:"JgjxrfrjhyrzIDeNcxJZ",organizerPhoto:"gdjGms_q_hAUJFj4_oGg",meetingDetails:"Jz4OFwufXu5IqISYgJLW",meetingSubject:"gpyySfRpe7gOlzUxvmVc",organizerName:"ugCe4qlevm8SQfhY_CJA",timeLabel:"PeM0vwMRQuvsfyVsACBb",startTimeDurationAndLocationSection:"heKzIeh3wdDVy_KIA64q",locationLabel:"TM1IwqFCDyAfGh7M2dHU",viewDetailsContainerWithoutBorder:"Erlgfqa7g2eqqYfu8SsL",viewDetailsContainer:"nUjROmlbjEY88LwN4U7U",viewDetailsContainerShort:"P2q1mNlSTuthMnyNBgC2",coloredText:"TSEUfBb55dffy1jKvbg3",viewDetails:"RIr_XtZNzZQix24O7fAI",sectionContainer:"KdsytqRryxncX4e80Ara",sectionValue:"xdrP0PGAODx2YNqNzW_3",viewMeetingDetailsIcon:"CiBjYJ3IvAiCqKUMQb0A",conflictSectionShort:"glIODd8_wxGnogzRfwow",conflictSectionLong:"qHZuDA6tr8_vASnHCaXA",conflictSectionHeading:"oe4gE_t3fx7So7BJKWF0",conflictS