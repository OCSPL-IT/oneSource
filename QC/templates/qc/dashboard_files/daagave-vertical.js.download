\n    margin-top: 8px;\n    display: inline-flex;\n    align-items: center;\n    cursor: pointer;\n}\n\n.quietTimeSettingLink {\n    margin-top: 8px;\n}\n\n.footerThumbStyle,\n.footerThumbStyle:hover {\n    width: 20px;\n    height: 20px;\n    padding: 0px;\n\n    [dir="ltr"] & {\n        margin-right: 4px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 4px;\n    }\n}\n\n.footerThumbSize {\n    width: 16px;\n    height: 16px;\n}\n\n.feedbackThumbsIconTipsStyle {\n    .contentStyle;\n    margin-top: 0;\n\n    [dir="ltr"] & {\n        margin-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 8px;\n    }\n}\n\n.feedbackTextFieldStyle {\n    margin: 16px 0px;\n    border: 1px solid;\n    border-radius: 2px;\n}\n\n.feedbackTextFieldStyle textarea {\n    resize: none;\n}\n\n.notificationLinkStyle {\n    font-size: 14px;\n    display: flex;\n    justify-content: center;\n    padding-bottom: 12px;\n}\n\n.footerCard {\n    position: relative;\n    margin: 16px 0px;\n}\n\n.flexCard {\n    display: flex;\n    color: #4a4a4a;\n    align-items: center;\n}\n\n.footerSubject {\n    font-size: 14px;\n    flex: 1 1 auto;\n}\n\n.thumbs {\n    flex: 0 0 80px;\n}\n\n.feedbackSubject {\n    font-size: 14px;\n    font-family: "Segoe UI Semilight";\n}\n\n.cancelButton {\n    margin: 16px 0;\n}\n\n.submitButton {\n    .cancelButton;\n\n    [dir="ltr"] & {\n        margin-left: 16px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 16px;\n    }\n}\n\n.commentInput {\n    margin-top: 10px;\n}\n\n.privacyStatement {\n    font-size: 12px;\n    font-family: "Segoe UI Semilight";\n}\n\n.feedbackPrivacyStatement {\n    .privacyStatement;\n    margin-top: 8px;\n}\n\n.feedbackPrivacyLink {\n    cursor: pointer;\n}\n\n.feedbackThumbsSubject {\n    .feedbackSubject;\n\n    [dir="ltr"] & {\n        margin-right: 14px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 14px;\n    }\n}\n\n.commentActions {\n    .flexCard;\n    justify-content: flex-end;\n}\n\n.feedbackFooterSubmitButton {\n    margin: 16px 0 0 0;\n}\n\n.feedbackFooterCancelButton {\n    .feedbackFooterSubmitButton;\n\n    [dir="ltr"] & {\n        margin-right: 16px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 16px;\n    }\n}\n\n.feedbackCommentNotificationLink {\n    &:hover {\n        text-decoration: underline;\n    }\n    font-family: "Segoe UI Semibold";\n}\n\n.timeSlot {\n    background-color: #dff6dd;\n    display: flex;\n    margin-top: 8px;\n    margin-bottom: 8px;\n    border-radius: 2px;\n    align-items: center;\n\n    [dir="ltr"] & {\n        padding-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 8px;\n    }\n}\n\n.timeSlotActionIcon {\n    color: #016677;\n\n    [dir="ltr"] & {\n        margin-right: 10px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 10px;\n    }\n\n    :hover {\n        background: transparent;\n    }\n}\n\n.timeStyle {\n    font-family: "Segoe UI Regular";\n    flex: 1 1 120px;\n    padding: 4px 0px;\n    white-space: nowrap;\n    font-size: 14px;\n}\n\n.editIconStyle {\n    font-size: 16px;\n    color: #018192;\n}\n\n.timePickersContainer {\n    display: flex;\n    width: 100%;\n    margin-top: 14px;\n}\n\n.timePicker {\n    width: 125px;\n\n    [dir="ltr"] & {\n        padding-right: 5px;\n    }\n\n    [dir="rtl"] & {\n        padding-left: 5px;\n    }\n}\n\n.timePickerOption {\n    font-size: 12px;\n}\n\n.goToFeedButton button {\n    width: 100%;\n    height: 28px;\n    font-size: 12px;\n    margin: 0px;\n}\n\n.feedbackIceCreamPageImgStyle {\n    margin-top: 120px;\n}\n\n.feedbackIceCreamPageTextStyle {\n    margin: 16px auto;\n    text-align: center;\n}\n\n.learnMoreLink {\n    &:hover {\n        text-decoration: underline;\n    }\n\n    cursor: pointer;\n    font-family: "Segoe UI";\n    font-weight: 400;\n    font-size: 14px;\n    line-height: 20px;\n    margin-top: 8px;\n}\n'],sourceRoot:""}]),n.locals={containerStyle:"hy7UMu9bR2PDCnPal7Mr",settingAndFeedbackTitle:"iK2sq4n4xiGKVWjVfAYH",settingAndFeedbac