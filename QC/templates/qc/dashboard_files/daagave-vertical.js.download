mes fade_in_and_out {\n    0% {\n        opacity: 0.2;\n        animation-timing-function: linear;\n    }\n    50% {\n        opacity: 1;\n        animation-timing-function: linear;\n    }\n    100% {\n        opacity: 0.2;\n        animation-timing-function: linear;\n    }\n}",'@import "../Card.module.less";\n@import "../../componentsv2/Common.module.less";\n\n@headerHeight: 32px;\n@overlayMarginTop: 16px;\n@overlayBottom: 20px;\n@headerWithOverlayMargin: @headerHeight + @overlayMarginTop;\n@overlaySubHeight: @headerWithOverlayMargin + @overlayBottom;\n\n.commonContainerStyle {\n    // not include padding left and right, used for each insight\n    max-width: @max-width;\n    min-width: @min-width;\n    margin: auto;\n}\n\n.commonContainerWithPaddingStyle {\n    // include padding left and right\n    max-width: @containerWithPadding-max-width;\n    min-width: @containerWithPadding-min-width;\n    margin: auto;\n}\n\n.headerContainerStyle {\n    display: flex;\n    height: @headerHeight;\n    padding-right: @padding;\n    padding-left: @padding;\n    position: relative;\n    align-items: center;\n}\n\n.stickyHeaderStyle {\n    width: 100%;\n    height: @headerHeight;\n    position: relative;\n}\n\n.routerChildContainerStyle {\n    position: absolute;\n    width: 100%;\n    height: calc(~"100% - @{headerHeight}");\n}\n\n.dimmingOverlayStyle {\n    position: absolute;\n    top: @headerWithOverlayMargin;\n    bottom: 0px;\n    left: 0px;\n    right: 0px;\n    background-color: white;\n    opacity: 0.6;\n    z-index: 3;\n}\n\n.overlayContainerStyle {\n    position: absolute;\n    top: @headerWithOverlayMargin;\n    height: calc(~"100% - @{overlaySubHeight}");\n    width: 100%;\n    z-index: 4;\n}\n\n.overlayContainerBoxWrapperStyle {\n    display: flex;\n    flex-direction: column;\n    height: 100%;\n}\n\n.overlayContainerBoxStyle {\n    &:extend(.commonContainerStyle);\n    display: flex;\n    flex-direction: column;\n    margin: 0 auto;\n    width: 100%;\n    min-height: 1px;\n    max-height: 100%;\n    border: 1px solid #64c8d8;\n    box-shadow: 0.1px 0.1px 0.1px rgba(0, 0, 0, 0.2);\n    background-color: white;\n}\n\n.overlayBodyStyle {\n    overflow-y: auto;\n    overflow-x: hidden;\n    margin-top: 10px;\n    flex: 1 1 auto;\n}\n\n.feedbackOverlayBodyStyle {\n    &:extend(.overlayBodyStyle);\n    padding-top: 0px;\n    padding-bottom: 23px;\n\n    [dir="ltr"] & {\n        padding-right: 23px;\n        padding-left: 30px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 30px;\n        padding-left: 23px;\n    }\n}\n\n.overlayCardHeaderStyle {\n    position: relative;\n    border-bottom: 1px solid #64c8d8;\n    flex: 0 0 auto;\n    display: flex;\n}\n\n.overlayCardFooterStyle {\n    border-top: 1px solid #64c8d8;\n    flex: 0 0 auto;\n    display: flex;\n    margin-top: 20px;\n}\n\n.overlayDismissButtonStyle {\n    display: flex;\n    justify-content: flex-end;\n    cursor: pointer;\n    padding-top: 10px;\n\n    [dir="ltr"] & {\n        padding-right: 10px;\n    }\n\n    [dir="rtl"] & {\n        padding-left: 10px;\n    }\n}\n\n.tutorialContainerStyle {\n    &:extend(.overlayContainerStyle);\n    top: @headerHeight;\n    width: 100%;\n}\n\n.pinTutorialContainerStyle {\n    &:extend(.overlayContainerStyle);\n    top: -12px;\n    right: 8px;\n    max-width: calc(~"@{max-width} - 8px");\n}\n\n// container for sticky header&footer\n.rootContainerStyle {\n    &:extend(.commonContainerWithPaddingStyle);\n    height: 100%;\n    cursor: default;\n    display: flex;\n    flex-direction: column;\n}\n\n.rootContainerStyleWithBackground {\n    border-top: 1px solid #e6e6e6;\n    background-color: #f9f9f9;\n    height: 100%;\n}\n\n// scrollable area between sticky header&footer\n.mainContentStyle {\n    width: 100%;\n    height: 100%;\n    overflow-y: auto;\n    padding-right: @padding; // Keeps padding between the elements and the scrollbar\n    padding-left: @padding;\n    position: relative; // Make sure overlayContainer calculate its\' position based on maincontent container.\n}\n\n// sticky footer (autoresize, pinned to container bottom)\n.stickyFooterStyle {\n    flex: 1 0 auto;\n    padding-top: 36px;\n    padding-bottom: 7px;\n    padding-right: @padding; // Keeps padding between the elements\n    padding-left: @padding;\n}\n\n.buildSubContainersStyle(@postfix, @height) {\n    .nonInContextContainerHeight_@{postfix} {\n        flex: 1 1 auto;\n        overflow-y: auto;\n        height: calc(100% - @height);\n    }\n}\n\n.buildSubContainersStyle(only, @noneHeight);\n.buildSubContainersStyle(inContextInsight, @inContextInsightCardHeight);\n\n.insightsContainerStyle {\n    position: relative;\n    overflow-y: hidden;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n}\n\n.textHyperLinkStyle {\n    color: #0078d7;\n    cursor: pointer;\n}\n\n.textHyperLinkStyle:hover {\n    text-decoration: underline;\n}\n\n.isExpanded {\n    height: 274px !important;\n}\n\n.errorImage {\n    margin: 30px auto 20px;\n    display: flex;\n    justify-content: center;\n}\n\n.errorTitle {\n    font-size: 14px;\n    line-height: 19px;\n}\n\n.errorBody {\n    font-size: 12px;\n    line-height: 16px;\n    width: 194px;\n    margin: 10px auto;\n}\n\n.section {\n    margin-top: 20px;\n    // resolving bug of IE browser for Flex layout in column direction\n    max-width: 100%;\n}\n'],sourceRoot:""}]),n.locals={commonContainerStyle:"t14MDv69QPzJs862CsmV",overlayContainerBoxStyle:"y5uzBgwQ_clhevvu4rnw",commonContainerWithPaddingStyle:"fQUbRUIDncvMJWRs1e3L",rootContainerStyle:"FkuAPGnrVAed4ir3zMRG",headerContainerStyle:"OxnLLaxXKnmrHultOlOx",stickyHeaderStyle:"WlG8Zay5vUKNku68LPf1",routerChildContainerStyle:"bQaA83CjjBsHClPZ4xAK",dimmingOverlayStyle:"eFVWOQ9mrFcRkpQFpAWu",overlayContainerStyle:"pAAG34jn342kgJ5lBA0c",tutorialContainerStyle:"Hs9aGkGhjLFlvP_Hb8cG",pinTutorialContainerStyle:"DepW_hPAUqxadVJqOqZT",overlayContainerBoxWrapperStyle:"ToFignUd_8jzkkXEoJZL",overlayBodyStyle:"AmCwK7H8N6shA4WUt_Ig