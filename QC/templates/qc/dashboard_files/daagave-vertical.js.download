gin-bottom: 12px;\n}\n\n.dropDownPreviewString {\n    .titleText;\n\n    font-size: 12px;\n}\n\n.dropDownPreviewStringWithoutNotification {\n    .dropDownPreviewString;\n\n    [dir="ltr"] & {\n        padding-left: 52px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 52px;\n    }\n}\n\n.dropDownPreviewStringWithNotification {\n    .dropDownPreviewString;\n\n    [dir="ltr"] & {\n        padding-left: 30px;\n    }\n\n    [dir="rtl"] & {\n        padding-right: 30px;\n    }\n}\n\n.dropdownHr {\n    margin: 15px 0 10px 0;\n}\n\n.datePickerTitle {\n    color: #1b1a19;\n    font-family: "Segoe UI Semibold";\n    font-size: 12px;\n    margin-top: 16px;\n    margin-bottom: 10px;\n}\n\n.bigTaskStatusIcon {\n    font-size: 24px;\n}\n\n.previewTaskLeftIconContainer {\n    flex: 0 0 40px;\n    vertical-align: bottom;\n    justify-content: flex-start;\n}\n\n.rowContainer {\n    margin: 8px 0;\n}\n\n.multiRowsContainer {\n    margin-top: 15px;\n}\n\n.chevronIcon {\n    font-size: 14px;\n    margin: 0;\n}\n\n.chevronButton {\n    width: 16px;\n    height: 16px;\n    &:hover {\n        background-color: transparent !important;\n    }\n}\n\n.taskActionButton {\n    margin-bottom: 8px;\n    margin-top: 16px;\n}\n\n.insightGroup {\n    margin-top: 20px;\n}\n\n.changeMark {\n    height: 100%;\n    font-size: 14px;\n\n    [dir="ltr"] & {\n        margin-right: 4px;\n    }\n\n    [dir="rtl"] & {\n        margin-left: 4px;\n    }\n}\n\n.buttonGroup {\n    display: flex;\n    flex-direction: row;\n    justify-content: flex-end;\n    width: 100%;\n}\n\n.cornerButton {\n    [dir="ltr"] & {\n        margin-left: 8px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 8px;\n    }\n}\n\n.basicButtonStyle {\n    font-size: 12px;\n    padding: 0 5px;\n    height: 28px;\n}\n\n.taskDone {\n    color: #cce080;\n}\n\n.taskNeedsReview {\n    color: #ffd067;\n}\n\n.taskNotCompleted {\n    color: #edebe9;\n}\n\n.previewIcon {\n    font-size: 16px;\n}\n\n.spaceBetween {\n    justify-content: space-between;\n}\n\n.autoReplyMessageTitle {\n    margin-top: 20px;\n    font-family: "Segoe UI Semibold";\n}\n\n.setAutoReplyGroup {\n    padding-left: 4px;\n    padding-right: 4px;\n}\n\n.loader {\n    margin-top: 20px;\n}\n\n.taskCardContainer {\n    position: relative;\n    margin-top: 10;\n    padding-bottom: 8px;\n}\n\n.positionRelative {\n    position: relative;\n}\n\n.dismissCard {\n    padding: 16px 15px;\n    background-color: white;\n    box-shadow: 0 1.6px 3.6px 0 rgba(0, 0, 0, 0.132), 0 0.3px 0.9px 0 rgba(0, 0, 0, 0.108);\n}\n\n.scheduleOofBottomButtonsContainer {\n    margin-top: 9px;\n}\n\n.checkBoxWithLabel:hover .checkBox {\n    background: #ffffff;\n    border-color: #1b1a19;\n}\n\n.checkBoxWithLabel .checkBox {\n    width: 16px;\n    height: 16px;\n    margin: auto 0;\n    border-color: #1b1a19;\n    background: #ffffff;\n}\n\n.selectAllCheckBox {\n    [dir="ltr"] & {\n        margin-left: 16px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 16px;\n    }\n\n    margin-top: 18px;\n    margin-bottom: 16px;\n}\n\n.checkMark {\n    color: #1b1a19;\n}\n\n.checkBoxText {\n    .descriptionText;\n\n    [dir="ltr"] & {\n        margin-left: 15px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 15px;\n    }\n}\n\n.spinner {\n    margin: auto 0;\n    height: 100%;\n}\n\n.referenceDiv {\n    position: relative;\n    width: 0;\n    height: 0;\n    [dir="ltr"] & {\n        float: right;\n    }\n    [dir="rtl"] & {\n        float: left;\n    }\n}\n\n.overlaidComponent {\n    position: absolute;\n    top: 6px;\n    [dir="ltr"] & {\n        right: 35px;\n    }\n    [dir="rtl"] & {\n        left: 35px;\n    }\n    z-index: 99;\n}\n\n.overlaidErrorMessage {\n    .overlaidComponent;\n    color: #e02b2b;\n    line-height: 17px;\n    [dir="ltr"] & {\n        text-align: right;\n    }\n    [dir="rtl"] & {\n        text-align: left;\n    }\n    width: 120px;\n}\n\n.errorIcon {\n    position: relative;\n    top: 1px;\n    [dir="ltr"] & {\n        margin-right: 3p