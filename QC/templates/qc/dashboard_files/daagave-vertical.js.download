px;\n    margin-bottom: 8px;\n}\n\n.attachmentIconSection {\n    display: flex;\n    width: 16px;\n    height: 20px;\n    align-items: center;\n}\n\n.attachmentIcon {\n    flex: 0 0 16px;\n    height: 16px;\n\n    [dir="ltr"] & {\n        margin-left: 5px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 5px;\n    }\n}\n\n.defaultFileIconStyle {\n    color: #b5b5b5;\n    font-size: 15px;\n    [dir="ltr"] & {\n        margin-left: 7px;\n    }\n\n    [dir="rtl"] & {\n        margin-right: 7px;\n    }\n}\n\n.cloudIcon {\n    position: relative;\n    z-index: 2;\n    height: 12px;\n    top: 6px;\n\n    [dir="ltr"] & {\n        left: -10px;\n    }\n\n    [dir="rtl"] & {\n        right: -10px;\n    }\n}\n\n.attachmentNameText {\n    .hideOverflow;\n    .textStyle;\n    color: #3b5db0;\n    max-width: 180px;\n    width: 202px;\n    height: 20px;\n\n    &:hover {\n        .hoverEffect;\n    }\n\n    margin: 0px 16px 0px;\n}\n\n.textStyle {\n    line-height: 20px;\n    font-size: 14px;\n    font-family: Segoe UI;\n    font-style: normal;\n    font-weight: 400;\n}\n\n.hideOverflow {\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n}\n\n.hoverEffect {\n    text-decoration: underline;\n    cursor: pointer;\n}\n\n.attachmentEntry {\n    margin-bottom: 12px;\n}\n'],sourceRoot:""}]),n.locals={attachmentSection:"e6nBjvSX1G8sFITZjcpy",attachmentStyle:"_EEKvZ5hezHsNdrEXAQx",attachmentDismissSection:"AgMSE0QcB47GnbkD7yg0",attachmentDismissIcon:"H_fpR5xOkrg3SDtqcGgR",relatedDocumentsSection:"X4fV4iPc1ZI3lFDHBStR",relatedDocumentsSectionStyle:"C1T4ZlIgvZKJQ3ERueW6",attachmentIconSection:"UeSEnkzI7MZ0aSiEXjcg",attachmentIcon:"AouhEwxAO3dv1B1fB6yE",defaultFileIconStyle:"KaZ4l6Jt09mXZoVlaFXB",cloudIcon:"yIVbI6DJif_L7Bz32k56",attachmentNameText:"_DA2w4bjZaEkxX55EDU4",textStyle:"cmgtjLUWY9Q4dR1Vkkss",hideOverflow:"H2cyv71iozSNbUkk0TYY",hoverEffect:"sEOEl4g2xfeNWaMrwgVL",attachmentEntry:"FM0r59TExfzDHDSs1rhY"},e.exports=n},54818:(e,t,n)=>{var i=n(78170)
